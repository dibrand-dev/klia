+              onClick={() => setPage((p) => Math.min(totalPages - 1, p + 1))}
+              className="btn-secondary"
+              style={{ padding: '6px 12px', fontSize: 12, opacity: page >= totalPages - 1 ? 0.5 : 1 }}
+            >
+              Siguiente
+            </button>
+          </div>
